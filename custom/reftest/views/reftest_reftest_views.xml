<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="reftest_reftest_view_list" model="ir.ui.view">
        <field name="name">reftest.reftest.view.list</field>
        <field name="model">reftest.reftest</field>
        <field name="arch" type="xml">
            <list>
                <header>
                    <button name="action_run_all" string="Run All" type="object" class="btn-primary" display="always"/>
                </header>
                <field name="report_id" width="320px"/>
                <field name="similarity_score" string="Similarity %" width="110px" widget="percentage" avg="Average"/>
                <field name="res_model" invisible="1"/>
                <field name="res_id"/>
                <field name="layout_id"/>
                <field name="reference_engine"/>
                <field name="engine"/>
            </list>
        </field>
    </record>

    <record id="reftest_reftest_view_form" model="ir.ui.view">
        <field name="name">reftest.reftest.view.form</field>
        <field name="model">reftest.reftest</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="run_test" string="Run" type="object" class="btn-primary"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="report_id"/>
                            <field name="res_model" invisible="1"/>
                            <field name="res_id"/>
                            <field name="layout_id"/>
                        </group>
                        <group>
                            <field name="similarity_score" widget="percentage" string="Similarity %"/>
                            <field name="reference_engine"/>
                            <field name="engine"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="documents" string="Documents">
                            <field name="output_pdf_ids" widget="many2many_binary" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter reload_on_attachment="True"/>
            </form>
        </field>
    </record>

    <record id="reftest_reftest_action" model="ir.actions.act_window">
        <field name="name">Reftests</field>
        <field name="res_model">reftest.reftest</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'group_by': ['report_id']}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Reftest record!
            </p>
        </field>
    </record>

</odoo>
